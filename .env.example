SEARCH_APP_API_KEY=replace-with-a-long-random-shared-secret
SEARCH_APP_OKTA_AUTH_ENABLED=false
SEARCH_APP_OKTA_ISSUER=https://example.okta.com/oauth2/default
SEARCH_APP_OKTA_AUDIENCE=api://search
SEARCH_APP_OKTA_JWKS_URL=https://example.okta.com/oauth2/default/v1/keys
SEARCH_APP_OKTA_CLAIM_SUB=sub
SEARCH_APP_OKTA_CLAIM_GROUPS=groups
SEARCH_APP_OKTA_CLAIM_DEPARTMENT=department
SEARCH_APP_OKTA_CLAIM_REGION=region
SEARCH_APP_OKTA_CLAIM_POSITION=position
SEARCH_APP_OKTA_CLAIM_MANAGER_ID=managerId
SEARCH_APP_ALLOWED_PROVIDER_HOSTS=docs.example.com,tickets.example.com
SEARCH_APP_REQUEST_TIMEOUT_SECONDS=5
SEARCH_APP_MAX_QUERY_LENGTH=120
SEARCH_APP_MAX_RESULTS_PER_PROVIDER=10
SEARCH_APP_ACL_ENABLED=true
SEARCH_APP_PROVIDERS__0__NAME=docs
SEARCH_APP_PROVIDERS__0__BASE_URL=https://docs.example.com
SEARCH_APP_PROVIDERS__0__SEARCH_PATH=/api/search
SEARCH_APP_PROVIDERS__0__BEARER_TOKEN=replace-with-docs-token
SEARCH_APP_PROVIDERS__1__NAME=tickets
SEARCH_APP_PROVIDERS__1__BASE_URL=https://tickets.example.com
SEARCH_APP_PROVIDERS__1__SEARCH_PATH=/api/search
SEARCH_APP_PROVIDERS__1__BEARER_TOKEN=replace-with-tickets-token
SEARCH_APP_ACL_POLICIES__0__PRINCIPAL=web-client
SEARCH_APP_ACL_POLICIES__0__ALLOWED_PROVIDERS=docs
SEARCH_APP_ACL_POLICIES__0__ALLOWED_GROUPS=trader
SEARCH_APP_ACL_POLICIES__0__ALLOWED_DEPARTMENTS=markets
SEARCH_APP_ACL_POLICIES__0__ALLOWED_REGIONS=apac,emea
SEARCH_APP_ACL_POLICIES__0__ALLOWED_POSITIONS=manager,individual-contributor
SEARCH_APP_ACL_POLICIES__0__MAX_QUERY_LENGTH=80
SEARCH_APP_ACL_POLICIES__0__MAX_RESULTS_PER_PROVIDER=5
SEARCH_APP_ACL_POLICIES__1__PRINCIPAL=ops-client
SEARCH_APP_ACL_POLICIES__1__ALLOWED_PROVIDERS=docs,tickets
SEARCH_APP_ACL_POLICIES__1__ALLOWED_GROUPS=internal-audit,compliance-officer
SEARCH_APP_ACL_POLICIES__1__ALLOWED_DEPARTMENTS=compliance
SEARCH_APP_ACL_POLICIES__1__ALLOWED_REGIONS=apac,emea,amer
SEARCH_APP_ACL_POLICIES__1__ALLOWED_POSITIONS=manager
SEARCH_APP_ACL_POLICIES__1__REQUIRE_MANAGER=true
