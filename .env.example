APP_ENV=development
PORT=8080
LOG_LEVEL=INFO
DEMO_MODE=echo

# Notion API
NOTION_API_TOKEN=<your_notion_api_token>
NOTION_PAGE_ID=<your_notion_page_id>
NOTION_ACTION=title

# Federated search backend
SEARCH_APP_API_KEY=replace-with-a-long-random-shared-secret
SEARCH_APP_OKTA_AUTH_ENABLED=false
SEARCH_APP_OKTA_ISSUER=https://example.okta.com/oauth2/default
SEARCH_APP_OKTA_AUDIENCE=api://search
SEARCH_APP_OKTA_JWKS_URL=https://example.okta.com/oauth2/default/v1/keys
SEARCH_APP_OKTA_CLAIM_SUB=sub
SEARCH_APP_OKTA_CLAIM_GROUPS=groups
SEARCH_APP_OKTA_CLAIM_DEPARTMENT=department
SEARCH_APP_OKTA_CLAIM_REGION=region
SEARCH_APP_OKTA_CLAIM_POSITION=position
SEARCH_APP_OKTA_CLAIM_MANAGER_ID=managerId
SEARCH_APP_ALLOWED_PROVIDER_HOSTS=docs.example.com,tickets.example.com
SEARCH_APP_REQUEST_TIMEOUT_SECONDS=5
SEARCH_APP_MAX_QUERY_LENGTH=120
SEARCH_APP_MAX_RESULTS_PER_PROVIDER=10
SEARCH_APP_ACL_ENABLED=true
SEARCH_APP_PROVIDERS__0__NAME=docs
SEARCH_APP_PROVIDERS__0__BASE_URL=https://docs.example.com
SEARCH_APP_PROVIDERS__0__SEARCH_PATH=/api/search
SEARCH_APP_PROVIDERS__0__BEARER_TOKEN=replace-with-docs-token
SEARCH_APP_PROVIDERS__1__NAME=tickets
SEARCH_APP_PROVIDERS__1__BASE_URL=https://tickets.example.com
SEARCH_APP_PROVIDERS__1__SEARCH_PATH=/api/search
SEARCH_APP_PROVIDERS__1__BEARER_TOKEN=replace-with-tickets-token
SEARCH_APP_ACL_POLICIES__0__PRINCIPAL=web-client
SEARCH_APP_ACL_POLICIES__0__ALLOWED_PROVIDERS=docs
SEARCH_APP_ACL_POLICIES__0__ALLOWED_GROUPS=trader
SEARCH_APP_ACL_POLICIES__0__ALLOWED_DEPARTMENTS=markets
SEARCH_APP_ACL_POLICIES__0__ALLOWED_REGIONS=apac,emea
SEARCH_APP_ACL_POLICIES__0__ALLOWED_POSITIONS=manager,individual-contributor
SEARCH_APP_ACL_POLICIES__0__MAX_QUERY_LENGTH=80
SEARCH_APP_ACL_POLICIES__0__MAX_RESULTS_PER_PROVIDER=5
SEARCH_APP_ACL_POLICIES__1__PRINCIPAL=ops-client
SEARCH_APP_ACL_POLICIES__1__ALLOWED_PROVIDERS=docs,tickets
SEARCH_APP_ACL_POLICIES__1__ALLOWED_GROUPS=internal-audit,compliance-officer
SEARCH_APP_ACL_POLICIES__1__ALLOWED_DEPARTMENTS=compliance
SEARCH_APP_ACL_POLICIES__1__ALLOWED_REGIONS=apac,emea,amer
SEARCH_APP_ACL_POLICIES__1__ALLOWED_POSITIONS=manager
SEARCH_APP_ACL_POLICIES__1__REQUIRE_MANAGER=true

# ETL pipeline
SEARCH_APP_ETL_ENABLED=false
SEARCH_APP_ETL_REQUEST_TIMEOUT_SECONDS=20
SEARCH_APP_ETL_DISCOVERY_ENGINE_LOAD_URL=https://discoveryengine.googleapis.com/v1/projects/your-project/locations/global/collections/default_collection/dataStores/your-datastore/branches/default_branch/documents:import
SEARCH_APP_ETL_BIGQUERY_TABLE=projects/your-project/datasets/search_ds/tables/documents

SEARCH_APP_ETL_SYSTEMS__0__NAME=servicenow
SEARCH_APP_ETL_SYSTEMS__0__IDENTITY_PROVIDER=okta
SEARCH_APP_ETL_SYSTEMS__0__EXTRACT_URL=https://api.servicenow.example.com/v1/documents
SEARCH_APP_ETL_SYSTEMS__0__TOKEN_URL=https://your-okta-domain/oauth2/default/v1/token
SEARCH_APP_ETL_SYSTEMS__0__SCOPE=servicenow.read
SEARCH_APP_ETL_SYSTEMS__0__CLIENT_ID_SECRET=SEARCH_APP_ETL_SECRET_SERVICENOW_OKTA_CLIENT_ID
SEARCH_APP_ETL_SYSTEMS__0__CLIENT_SECRET_SECRET=SEARCH_APP_ETL_SECRET_SERVICENOW_OKTA_CLIENT_SECRET
SEARCH_APP_ETL_SYSTEMS__0__RECORDS_FIELD=items

SEARCH_APP_ETL_SYSTEMS__1__NAME=workday
SEARCH_APP_ETL_SYSTEMS__1__IDENTITY_PROVIDER=entra_id
SEARCH_APP_ETL_SYSTEMS__1__EXTRACT_URL=https://api.workday.example.com/v1/workers
SEARCH_APP_ETL_SYSTEMS__1__TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
SEARCH_APP_ETL_SYSTEMS__1__SCOPE=https://workday.example.com/.default
SEARCH_APP_ETL_SYSTEMS__1__CLIENT_ID_SECRET=SEARCH_APP_ETL_SECRET_WORKDAY_ENTRA_CLIENT_ID
SEARCH_APP_ETL_SYSTEMS__1__CLIENT_SECRET_SECRET=SEARCH_APP_ETL_SECRET_WORKDAY_ENTRA_CLIENT_SECRET
SEARCH_APP_ETL_SYSTEMS__1__RECORDS_FIELD=items

SEARCH_APP_ETL_SYSTEMS__2__NAME=compliance-system
SEARCH_APP_ETL_SYSTEMS__2__IDENTITY_PROVIDER=okta_ldap_agent
SEARCH_APP_ETL_SYSTEMS__2__EXTRACT_URL=https://compliance.example.com/api/v1/records
SEARCH_APP_ETL_SYSTEMS__2__USERNAME_SECRET=SEARCH_APP_ETL_SECRET_COMPLIANCE_LDAP_USERNAME
SEARCH_APP_ETL_SYSTEMS__2__PASSWORD_SECRET=SEARCH_APP_ETL_SECRET_COMPLIANCE_LDAP_PASSWORD
SEARCH_APP_ETL_SYSTEMS__2__RECORDS_FIELD=items

SEARCH_APP_ETL_SYSTEMS__3__NAME=sharepoint
SEARCH_APP_ETL_SYSTEMS__3__IDENTITY_PROVIDER=entra_id
SEARCH_APP_ETL_SYSTEMS__3__EXTRACT_URL=https://graph.microsoft.com/v1.0/sites/<site-id>/lists/<list-id>/items
SEARCH_APP_ETL_SYSTEMS__3__TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
SEARCH_APP_ETL_SYSTEMS__3__SCOPE=https://graph.microsoft.com/.default
SEARCH_APP_ETL_SYSTEMS__3__CLIENT_ID_SECRET=SEARCH_APP_ETL_SECRET_SHAREPOINT_ENTRA_CLIENT_ID
SEARCH_APP_ETL_SYSTEMS__3__CLIENT_SECRET_SECRET=SEARCH_APP_ETL_SECRET_SHAREPOINT_ENTRA_CLIENT_SECRET
SEARCH_APP_ETL_SYSTEMS__3__RECORDS_FIELD=value

SEARCH_APP_ETL_SYSTEMS__4__NAME=confluence
SEARCH_APP_ETL_SYSTEMS__4__IDENTITY_PROVIDER=okta
SEARCH_APP_ETL_SYSTEMS__4__EXTRACT_URL=https://confluence.example.com/wiki/rest/api/content
SEARCH_APP_ETL_SYSTEMS__4__TOKEN_URL=https://your-okta-domain/oauth2/default/v1/token
SEARCH_APP_ETL_SYSTEMS__4__SCOPE=confluence.read
SEARCH_APP_ETL_SYSTEMS__4__CLIENT_ID_SECRET=SEARCH_APP_ETL_SECRET_CONFLUENCE_OKTA_CLIENT_ID
SEARCH_APP_ETL_SYSTEMS__4__CLIENT_SECRET_SECRET=SEARCH_APP_ETL_SECRET_CONFLUENCE_OKTA_CLIENT_SECRET
SEARCH_APP_ETL_SYSTEMS__4__RECORDS_FIELD=results
